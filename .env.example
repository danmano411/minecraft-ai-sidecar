# ═══════════════════════════════════════════════════════════════════════════
#  Minecraft AI Helper — environment configuration
#
#  Copy this file to .env and fill in the values for the backend you choose.
#  You do NOT need all API keys — only the ones for your selected backends.
# ═══════════════════════════════════════════════════════════════════════════


# ── LLM Backend ─────────────────────────────────────────────────────────────
#  Recommended for testing (FREE): "ollama"
#  Recommended for testing (FREE cloud): "groq"
#  Production (best quality, paid): "anthropic"
LLM_BACKEND=ollama


# ── Embedding Backend ────────────────────────────────────────────────────────
#  Recommended for testing (FREE): "ollama"
#  Production (paid): "openai"
EMBEDDING_BACKEND=ollama


# ── API Keys ─────────────────────────────────────────────────────────────────
#  Only fill in the keys for the backends you are using.

# Anthropic — required only if LLM_BACKEND=anthropic
#ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — required only if EMBEDDING_BACKEND=openai
#OPENAI_API_KEY=your_openai_api_key_here

# Groq — required only if LLM_BACKEND=groq  (free at console.groq.com)
#GROQ_API_KEY=your_groq_api_key_here

# Tavily — optional; community agent is skipped if not set
TAVILY_API_KEY=your_tavily_api_key_here


# ── Model Names ───────────────────────────────────────────────────────────────
#  Active: Ollama local models (free).
#  Run these two commands before starting the server:
#
#    ollama pull llama3.2:3b         (~2 GB)  — LLM for all agents
#    ollama pull nomic-embed-text    (~274 MB) — embeddings for RAG
#
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

#  ── To switch to paid production models, uncomment these and comment out above:
#LLM_BACKEND=anthropic
#EMBEDDING_BACKEND=openai
#ANTHROPIC_API_KEY=your_anthropic_api_key_here
#OPENAI_API_KEY=your_openai_api_key_here
#LLM_MODEL=claude-opus-4-8
#EMBEDDING_MODEL=text-embedding-3-small
#EMBEDDING_DIMENSIONS=1536

#  ── To use Groq (free cloud LLM, still needs Ollama for embeddings):
#LLM_BACKEND=groq
#GROQ_API_KEY=your_groq_api_key_here
#LLM_MODEL=llama-3.1-8b-instant


# ── Ollama server ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1


# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
LOG_LEVEL=info


# ── Storage ───────────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma

# ⚠ If you switch EMBEDDING_BACKEND or EMBEDDING_MODEL after already running
#   "minecraft-ai build", delete ./data/chroma/ and rebuild — dimensions must match.
